# ===========================================
# VARIABLES DE ENTORNO
# ===========================================
# Copia este archivo como .env y completa con tus valores reales.
# NUNCA subas .env a Git (contiene datos sensibles).
# ===========================================

# --- Base de datos PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_example
DB_USER=gr_example
DB_PASSWORD=tu_contraseña_aqui

# --- JWT (autenticación) ---
# Clave secreta para firmar tokens. Mínimo 32 caracteres aleatorios.
# Generar con: openssl rand -base64 32
JWT_SECRET=cambiar_por_clave_segura_minimo_32_caracteres

# --- Entorno ---
# desarrollo | produccion
APP_ENV=desarrollo
